# Copie para .env e ajuste os valores
APP_NAME=pjsa-api
DEBUG=false

# PostgreSQL (local ou Docker)
DATABASE_URL=postgresql+asyncpg://pjsa:pjsa@localhost:5432/pjsa

# Docker Compose: porta publicada no teu PC (host:contentor). Não altera a porta com que a API fala
# com o Postgres *dentro* da rede Docker (essa é sempre 5432 no serviço "postgres").
# Se a 5432 estiver ocupada, usa por exemplo POSTGRES_PORT=5433
POSTGRES_PORT=5432
POSTGRES_USER=pjsa
POSTGRES_PASSWORD=pjsa
POSTGRES_DB=pjsa

JWT_SECRET=altere-para-uma-string-longa-e-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Opcional: cria utilizador admin na primeira subida (apenas se o username ainda não existir)
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=admin
ADMIN_SEED_FULL_NAME=Administrador
